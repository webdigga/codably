---
export interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<div class="feedback-buttons" data-slug={slug}>
  <span class="feedback-label">Was this article helpful?</span>
  <div class="feedback-actions">
    <button class="btn feedback-btn" data-vote="up" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 10v12" />
        <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z" />
      </svg>
      <span class="feedback-count" data-count="up">0</span>
    </button>
    <button class="btn feedback-btn" data-vote="down" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 14V2" />
        <path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22a3.13 3.13 0 0 1-3-3.88Z" />
      </svg>
      <span class="feedback-count" data-count="down">0</span>
    </button>
  </div>
</div>

<style>
  .feedback-buttons {
    margin-top: var(--space-8);
    padding: var(--space-6);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .feedback-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .feedback-actions {
    display: flex;
    gap: var(--space-2);
  }

  .feedback-btn {
    transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .feedback-btn.voted {
    background: var(--brand-primary);
    color: #ffffff;
    border-color: var(--brand-primary);
  }

  .feedback-btn.voted:hover {
    background: var(--brand-primary-hover);
    border-color: var(--brand-primary-hover);
    color: #ffffff;
  }

  .feedback-btn.bounce {
    animation: vote-bounce 0.3s ease;
  }

  @keyframes vote-bounce {
    0% { transform: scale(1); }
    40% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }
</style>

<script>
  document.querySelectorAll('.feedback-buttons').forEach((container) => {
    const slug = container.getAttribute('data-slug');
    if (!slug) return;

    const upBtn = container.querySelector('[data-vote="up"]') as HTMLButtonElement;
    const downBtn = container.querySelector('[data-vote="down"]') as HTMLButtonElement;
    const upCount = container.querySelector('[data-count="up"]') as HTMLElement;
    const downCount = container.querySelector('[data-count="down"]') as HTMLElement;
    const storageKey = `voted:${slug}`;

    // Restore voted state from localStorage
    const savedVote = localStorage.getItem(storageKey) as 'up' | 'down' | null;
    if (savedVote === 'up') upBtn.classList.add('voted');
    if (savedVote === 'down') downBtn.classList.add('voted');

    // Fetch current counts
    fetch(`/api/votes?slug=${encodeURIComponent(slug)}`)
      .then((res) => res.ok ? res.json() : Promise.reject())
      .then((data: { up: number; down: number }) => {
        upCount.textContent = String(data.up);
        downCount.textContent = String(data.down);
      })
      .catch(() => {});

    function handleVote(vote: 'up' | 'down') {
      const previous = localStorage.getItem(storageKey) as 'up' | 'down' | null;

      // If clicking the same vote, do nothing
      if (previous === vote) return;

      const btn = vote === 'up' ? upBtn : downBtn;
      const otherBtn = vote === 'up' ? downBtn : upBtn;
      const countEl = vote === 'up' ? upCount : downCount;
      const otherCountEl = vote === 'up' ? downCount : upCount;

      // Optimistic UI update
      btn.classList.add('voted', 'bounce');
      otherBtn.classList.remove('voted');
      countEl.textContent = String(parseInt(countEl.textContent || '0') + 1);
      if (previous) {
        otherCountEl.textContent = String(Math.max(0, parseInt(otherCountEl.textContent || '0') - 1));
      }

      // Remove bounce class after animation
      btn.addEventListener('animationend', () => btn.classList.remove('bounce'), { once: true });

      // Save to localStorage
      localStorage.setItem(storageKey, vote);

      // Submit to API
      fetch('/api/votes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, vote, ...(previous ? { previous } : {}) }),
      })
        .then((res) => res.ok ? res.json() : Promise.reject())
        .then((data: { up: number; down: number }) => {
          upCount.textContent = String(data.up);
          downCount.textContent = String(data.down);
        })
        .catch(() => {});
    }

    upBtn.addEventListener('click', () => handleVote('up'));
    downBtn.addEventListener('click', () => handleVote('down'));
  });
</script>
