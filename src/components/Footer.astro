---
import { categories } from '../data/categories';
import { authors } from '../data/authors';
import NewsletterButton from './NewsletterButton.astro';

const currentYear = new Date().getFullYear();
const authorList = Object.values(authors);
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-grid">
      <div class="footer-col">
        <h3>Categories</h3>
        <ul>
          {categories.map((cat) => (
            <li><a href={`/${cat.slug}`}>{cat.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h3>Pages</h3>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/start-here">Start Here</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Use</a></li>
          <li><a href="/rss.xml">RSS Feed</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3>Authors</h3>
        <ul>
          {authorList.map((author) => (
            <li><a href={`/author/${author.slug}`}>{author.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h3>About Codably</h3>
        <p>Practical developer productivity advice. Better tools, sharper workflows, real results.</p>
        <div class="footer-subscribe">
          <NewsletterButton label="Subscribe" />
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Codably. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-16);
    padding: var(--space-12) 0 var(--space-8);
    border-top: none;
    background: #111827;
    color: #9ca3af;
  }

  .footer-grid {
    display: grid;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr 1fr;
    }
  }

  .footer-col h3 {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #e5e7eb;
    margin-bottom: var(--space-4);
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
  }

  .footer-col li {
    margin-bottom: var(--space-2);
  }

  .footer-col a {
    font-size: var(--text-sm);
    color: #9ca3af;
    text-decoration: none;
  }

  .footer-col a:hover {
    color: #ffffff;
  }

  .footer-col p {
    font-size: var(--text-sm);
    color: #9ca3af;
    line-height: var(--leading-relaxed);
  }

  .footer-subscribe {
    margin-top: var(--space-4);
  }

  .footer-bottom {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid #1f2937;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: #9ca3af;
  }

  .footer-bottom a {
    color: #9ca3af;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-bottom a:hover {
    color: #ffffff;
  }
</style>
