<a
  href="https://implera.ai?utm_source=codably&utm_medium=banner&utm_campaign=editorial"
  target="_blank"
  rel="noopener noreferrer"
  class="banner"
>
  <svg class="banner-logo" viewBox="0 0 512 512" aria-hidden="true">
    <rect width="512" height="512" rx="96" fill="#ffffff"/>
    <path d="M128 160 L256 256 L128 352" stroke="#6366f1" stroke-width="48" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <line x1="256" y1="256" x2="384" y2="256" stroke="#6366f1" stroke-width="48" stroke-linecap="round"/>
  </svg>
  <span class="banner-text">
    AI writes the code. Implera watches the quality.
  </span>
  <span class="banner-cta">Get your score</span>
</a>

<style>
  .banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: #6366f1;
    color: #ffffff;
    font-size: var(--text-sm);
    text-decoration: none;
    text-align: center;
    position: relative;
    z-index: var(--z-banner);
    transition: background-color 0.15s ease;
  }

  .banner:hover {
    background: #4f46e5;
    color: #ffffff;
  }

  .banner-logo {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .banner-text {
    line-height: var(--leading-tight);
  }

  .banner-cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    background: #ffffff;
    color: #6366f1;
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .banner {
      padding: var(--space-3) var(--space-6);
      font-size: var(--text-base);
      gap: var(--space-4);
    }
  }
</style>
