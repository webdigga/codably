<a
  href="https://kabooly.com?utm_source=crmbeat&utm_medium=banner&utm_campaign=editorial"
  target="_blank"
  rel="noopener noreferrer"
  class="banner"
>
  <svg class="banner-logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <path d="M2 8 Q6 4 12 8 T22 8"></path>
    <path d="M2 12 Q6 8 12 12 T22 12"></path>
    <path d="M2 16 Q6 12 12 16 T22 16"></path>
  </svg>
  <span class="banner-text">
    The simple CRM built for UK small businesses
  </span>
  <span class="banner-cta">Try Kabooly free</span>
</a>

<style>
  .banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: #2563eb;
    color: #ffffff;
    font-size: var(--text-sm);
    text-decoration: none;
    text-align: center;
    position: relative;
    z-index: var(--z-banner);
    transition: background-color 0.15s ease;
  }

  .banner:hover {
    background: #1d4ed8;
    color: #ffffff;
  }

  .banner-logo {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .banner-text {
    line-height: var(--leading-tight);
  }

  .banner-cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    background: #ffffff;
    color: #2563eb;
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .banner {
      padding: var(--space-3) var(--space-6);
      font-size: var(--text-base);
      gap: var(--space-4);
    }
  }
</style>
