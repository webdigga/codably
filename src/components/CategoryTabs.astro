---
import { categories } from '../data/categories';

export interface Props {
  activeCategory?: string;
}

const { activeCategory } = Astro.props;
---

<nav class="category-tabs" aria-label="Article categories">
  <div class="tabs-scroll-wrapper">
    <div class="tabs-scroll">
      <a
        href="/"
        class:list={['tab', { active: !activeCategory }]}
      >
        All
      </a>
      {categories.map((cat) => (
        <a
          href={`/${cat.slug}`}
          class:list={['tab', { active: activeCategory === cat.slug }]}
        >
          {cat.name}
        </a>
      ))}
    </div>
    <div class="tabs-fade tabs-fade-left" aria-hidden="true"></div>
    <div class="tabs-fade tabs-fade-right" aria-hidden="true"></div>
  </div>
</nav>

<style>
  .category-tabs {
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .tabs-scroll-wrapper {
    position: relative;
  }

  .tabs-scroll {
    display: flex;
    gap: var(--space-1);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .tabs-scroll::-webkit-scrollbar {
    display: none;
  }

  .tab {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .tab:hover {
    color: var(--color-text);
  }

  .tab.active {
    color: var(--color-text);
    border-bottom-color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  .tabs-fade {
    display: none;
    position: absolute;
    top: 0;
    bottom: 1px;
    width: 40px;
    pointer-events: none;
    z-index: 1;
  }

  .tabs-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--color-bg), transparent);
  }

  .tabs-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--color-bg), transparent);
  }

  .tabs-fade.visible {
    display: block;
  }
</style>

<script>
  const wrapper = document.querySelector('.tabs-scroll-wrapper');
  const scroller = wrapper?.querySelector('.tabs-scroll') as HTMLElement | null;
  const fadeLeft = wrapper?.querySelector('.tabs-fade-left') as HTMLElement | null;
  const fadeRight = wrapper?.querySelector('.tabs-fade-right') as HTMLElement | null;

  function updateFades() {
    if (!scroller || !fadeLeft || !fadeRight) return;
    const { scrollLeft, scrollWidth, clientWidth } = scroller;
    fadeLeft.classList.toggle('visible', scrollLeft > 4);
    fadeRight.classList.toggle('visible', scrollLeft + clientWidth < scrollWidth - 4);
  }

  if (scroller) {
    updateFades();
    scroller.addEventListener('scroll', updateFades, { passive: true });
    window.addEventListener('resize', updateFades, { passive: true });

    // Scroll active tab into view on load
    const activeTab = scroller.querySelector('.tab.active') as HTMLElement | null;
    if (activeTab) {
      activeTab.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'instant' });
      // Re-check fades after scroll
      requestAnimationFrame(updateFades);
    }
  }
</script>
