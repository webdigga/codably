---
import { categories } from '../data/categories';
import { authors } from '../data/authors';

export interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  author: string;
  publishDate: string;
  wordCount?: number;
  headingLevel?: 2 | 3;
}

const { title, description, slug, category, author, publishDate, wordCount = 0, headingLevel = 2 } = Astro.props;
const Heading = `h${headingLevel}` as any;

const cat = categories.find((c) => c.slug === category);
const authorData = authors[author];
const authorName = authorData?.name || author;
const authorAvatar = authorData?.avatar;
const readingTime = Math.max(1, Math.ceil(wordCount / 230));
const dateFormatted = new Date(publishDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class="card article-card" data-slug={slug}>
  <a href={`/${category}/${slug}`} class="article-card-link">
    <div class="article-card-topline">
      {cat && (
        <span class="article-card-category">
          {cat.name}
        </span>
      )}
      <span class="card-engagement" style="display:none;">
        <span class="card-likes" style="display:none;">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 3l1-2 1 2 1.5 3H14l-3 3 1 4-4-2-4 2 1-4-3-3h3.5z"></path></svg>
          <span class="card-likes-count"></span>
        </span>
        <span class="card-comments" style="display:none;">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h12v8H5l-3 3V3z"></path></svg>
          <span class="card-comments-count"></span>
        </span>
      </span>
    </div>
    <Heading class="article-card-title">{title}</Heading>
    <p class="article-card-excerpt">{description}</p>
    <div class="article-card-meta">
      {authorAvatar && (
        <img src={authorAvatar} alt={authorName} class="article-card-avatar" width="20" height="20" loading="lazy" />
      )}
      <span>{authorName}</span>
      <span class="meta-separator">&middot;</span>
      <time datetime={publishDate}>{dateFormatted}</time>
      {wordCount > 0 && (
        <>
          <span class="meta-separator">&middot;</span>
          <span>{readingTime} min read</span>
        </>
      )}
    </div>
  </a>
</article>

<style is:global>
  .article-card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .article-card-category {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-tertiary);
  }

  .article-card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
  }

  .article-card-link:hover {
    color: inherit;
  }

  .article-card-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    transition: color var(--transition-fast);
    margin: 0;
  }

  .article-card-link:hover .article-card-title {
    color: var(--color-link);
  }

  .article-card-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-top: auto;
  }

  .article-card-avatar {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    object-fit: cover;
  }

  .meta-separator {
    color: var(--color-text-tertiary);
  }

  .card-engagement {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .card-likes,
  .card-comments {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .card-likes svg,
  .card-comments svg {
    flex-shrink: 0;
  }
</style>

<script>
  function populateCardEngagement(
    card: Element,
    stats: { comments: Record<string, number>; votes: Record<string, { up: number; down: number }> }
  ) {
    const slug = card.getAttribute('data-slug');
    if (!slug) return;

    const likes = stats.votes[slug]?.up || 0;
    const comments = stats.comments[slug] || 0;

    if (likes > 0) {
      const likesEl = card.querySelector('.card-likes') as HTMLElement;
      const likesCount = card.querySelector('.card-likes-count');
      if (likesEl && likesCount) {
        likesCount.textContent = String(likes);
        likesEl.style.display = '';
      }
    }

    if (comments > 0) {
      const commentsEl = card.querySelector('.card-comments') as HTMLElement;
      const commentsCount = card.querySelector('.card-comments-count');
      if (commentsEl && commentsCount) {
        commentsCount.textContent = String(comments);
        commentsEl.style.display = '';
      }
    }

    if (likes > 0 || comments > 0) {
      const engagement = card.querySelector('.card-engagement') as HTMLElement;
      if (engagement) engagement.style.display = '';
    }
  }

  fetch('/api/stats')
    .then((r) => r.ok ? r.json() : Promise.reject())
    .then((stats: { comments: Record<string, number>; votes: Record<string, { up: number; down: number }> }) => {
      document.querySelectorAll('.article-card').forEach((card) => populateCardEngagement(card, stats));

      // Watch for dynamically added cards (e.g. popular sections, search results)
      const observer = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          for (const node of mutation.addedNodes) {
            if (node instanceof HTMLElement) {
              if (node.classList.contains('article-card')) {
                populateCardEngagement(node, stats);
              }
              node.querySelectorAll?.('.article-card').forEach((card) => populateCardEngagement(card, stats));
            }
          }
        }
      });
      observer.observe(document.body, { childList: true, subtree: true });
    })
    .catch(() => {});
</script>
