---
import SEOHead from '../components/SEOHead.astro';
import Banner from '../components/Banner.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  schemas?: object[];
  prevUrl?: string;
  nextUrl?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, ogType, schemas, prevUrl, nextUrl, noindex } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      schemas={schemas}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      noindex={noindex}
    />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved) {
          document.documentElement.setAttribute('data-theme', saved);
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <Banner />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      fetch('/api/stats')
        .then((res) => (res.ok ? res.json() : Promise.reject()))
        .then((data: { comments: Record<string, number>; votes: Record<string, { up: number; down: number }> }) => {
          document.querySelectorAll('.article-card[data-slug]').forEach((card) => {
            const slug = card.getAttribute('data-slug');
            if (!slug) return;

            const commentCount = data.comments[slug] || 0;
            const likeCount = data.votes[slug]?.up || 0;

            if (commentCount === 0 && likeCount === 0) return;

            const engagement = card.querySelector('.card-engagement') as HTMLElement;
            if (!engagement) return;

            if (likeCount > 0) {
              const likes = engagement.querySelector('.card-likes') as HTMLElement;
              const likesCount = engagement.querySelector('.card-likes-count') as HTMLElement;
              if (likes && likesCount) {
                likesCount.textContent = String(likeCount);
                likes.style.display = '';
              }
            }

            if (commentCount > 0) {
              const comments = engagement.querySelector('.card-comments') as HTMLElement;
              const commentsCount = engagement.querySelector('.card-comments-count') as HTMLElement;
              if (comments && commentsCount) {
                commentsCount.textContent = String(commentCount);
                comments.style.display = '';
              }
            }

            engagement.style.display = '';
          });
        })
        .catch(() => {});
    </script>
  </body>
</html>
