---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

import TableOfContents from '../components/TableOfContents.astro';
import FAQSection from '../components/FAQSection.astro';
import FeedbackButtons from '../components/FeedbackButtons.astro';
import ShareButtons from '../components/ShareButtons.astro';
import ArticleComments from '../components/ArticleComments.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { categories } from '../data/categories';
import { authors } from '../data/authors';

export interface Props {
  title: string;
  description: string;
  publishDate: string;
  dateModified?: string;
  author: string;
  category: string;
  slug: string;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  faqs?: { question: string; answer: string }[];
  wordCount: number;
  relatedArticles?: any[];
  schemas?: object[];
}

const {
  title,
  description,
  publishDate,
  dateModified,
  author,
  category,
  slug,
  tags,
  headings,
  faqs = [],
  wordCount,
  relatedArticles = [],
  schemas = [],
} = Astro.props;

const cat = categories.find((c) => c.slug === category);
const authorData = authors[author] || { name: author, role: '', bio: '', avatar: '', linkedin: '' };
const readingTime = Math.max(1, Math.ceil(wordCount / 230));
const dateFormatted = new Date(publishDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const showModified = dateModified && dateModified !== publishDate;
const modifiedFormatted = showModified
  ? new Date(dateModified).toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : '';
const url = new URL(Astro.url.pathname, Astro.site).href;

const crumbs = [
  { label: 'Home', href: '/' },
  ...(cat ? [{ label: cat.name, href: `/${cat.slug}` }] : []),
  { label: title },
];
---

<BaseLayout title={title} description={description} ogType="article" schemas={schemas}>
  <article class="container article-page">
    <Breadcrumbs crumbs={crumbs} />

    <div class="article-layout">
      <div class="article-main">
        <div class="article-header">
          {cat && (
            <a href={`/${cat.slug}`} class="article-category">
              {cat.name}
            </a>
          )}

          <h1>{title}</h1>

          <div class="article-meta">
            <a href={`/author/${author}`} class="meta-author-link">
              {authorData.avatar && (
                <img src={authorData.avatar} alt={authorData.name} class="meta-avatar" width="32" height="32" />
              )}
              <span class="meta-author">{authorData.name}</span>
            </a>
            <span class="meta-sep">&middot;</span>
            <time datetime={publishDate}>{dateFormatted}</time>
            {showModified && (
              <>
                <span class="meta-sep">&middot;</span>
                <span class="meta-updated">Updated <time datetime={dateModified}>{modifiedFormatted}</time></span>
              </>
            )}
            <span class="meta-sep">&middot;</span>
            <span>{readingTime} min read</span>
          </div>
        </div>

        <div class="prose">
          <slot />
        </div>

        {faqs.length > 0 && <FAQSection faqs={faqs} />}

        <FeedbackButtons slug={slug} />

        <ShareButtons title={title} url={url} />

        <ArticleComments slug={slug} />
      </div>

      <aside class="article-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <RelatedArticles articles={relatedArticles} />
  </article>
</BaseLayout>

<style>
  .article-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .article-header {
    margin-bottom: var(--space-10);
  }

  .article-category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .article-category:hover {
    color: var(--color-text-secondary);
  }

  .article-header h1 {
    margin-bottom: var(--space-4);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .meta-sep {
    color: var(--color-text-secondary);
  }

  .meta-avatar {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    object-fit: cover;
  }

  .meta-updated {
    font-style: italic;
  }

  .meta-author-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-link);
  }

  .meta-author-link:hover {
    text-decoration: underline;
  }

  .meta-author {
    font-weight: var(--weight-medium);
  }

  .article-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .article-main {
    min-width: 0;
  }

  .article-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .article-layout {
      flex-direction: row;
      gap: var(--space-16);
    }

    .article-main {
      flex: 1;
      min-width: 0;
    }

    .article-sidebar {
      display: block;
      width: 260px;
      flex-shrink: 0;
      position: sticky;
      top: calc(56px + var(--space-6));
      align-self: flex-start;
    }
  }
</style>
