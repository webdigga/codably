---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

import TableOfContents from '../components/TableOfContents.astro';
import FAQSection from '../components/FAQSection.astro';
import FeedbackButtons from '../components/FeedbackButtons.astro';
import ShareButtons from '../components/ShareButtons.astro';
import NewsletterButton from '../components/NewsletterButton.astro';
import ArticleComments from '../components/ArticleComments.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { categories } from '../data/categories';
import { authors } from '../data/authors';
import { slugifyTag, displayTag } from '../utils/tags';

export interface Props {
  title: string;
  description: string;
  publishDate: string;
  dateModified?: string;
  author: string;
  category: string;
  slug: string;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  faqs?: { question: string; answer: string }[];
  wordCount: number;
  relatedArticles?: any[];
  schemas?: object[];
}

const {
  title,
  description,
  publishDate,
  dateModified,
  author,
  category,
  slug,
  tags,
  headings,
  faqs = [],
  wordCount,
  relatedArticles = [],
  schemas = [],
} = Astro.props;

const cat = categories.find((c) => c.slug === category);
const authorData = authors[author] || { name: author, role: '', bio: '', avatar: '', linkedin: '' };
const readingTime = Math.max(1, Math.ceil(wordCount / 230));
const dateFormatted = new Date(publishDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const showModified = dateModified && dateModified !== publishDate;
const modifiedFormatted = showModified
  ? new Date(dateModified).toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : '';
const url = new URL(Astro.url.pathname, Astro.site).href;

const crumbs = [
  { label: 'Home', href: '/' },
  ...(cat ? [{ label: cat.name, href: `/${cat.slug}` }] : []),
  { label: title },
];
---

<BaseLayout title={title} description={description} ogType="article" schemas={schemas}>
  <div class="reading-progress"></div>
  <article class="container article-page">
    <Breadcrumbs crumbs={crumbs} />

    <div class="article-layout">
      <div class="article-main">
        <div class="article-header">
          {cat && (
            <a href={`/${cat.slug}`} class="article-category">
              {cat.name}
            </a>
          )}

          <h1>{title}</h1>

          <div class="article-meta">
            <a href={`/author/${author}`} class="meta-author-link">
              {authorData.avatar && (
                <img src={authorData.avatar} alt={authorData.name} class="meta-avatar" width="32" height="32" />
              )}
              <span class="meta-author">{authorData.name}</span>
            </a>
            <span class="meta-sep">&middot;</span>
            <time datetime={publishDate}>{dateFormatted}</time>
            {showModified && (
              <>
                <span class="meta-sep">&middot;</span>
                <span class="meta-updated">Updated <time datetime={dateModified}>{modifiedFormatted}</time></span>
              </>
            )}
            <span class="meta-sep">&middot;</span>
            <span class="reading-time-badge">{readingTime} min read</span>
            <span class="meta-sep">&middot;</span>
            <a href="#comments" class="meta-comments-link">
              <svg class="meta-comments-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
              <span class="meta-comment-count"></span>
            </a>
          </div>

          {tags.length > 0 && (
            <div class="article-tags">
              {tags.map((tag) => (
                <a href={`/tag/${slugifyTag(tag)}`} class="article-tag">{displayTag(tag)}</a>
              ))}
            </div>
          )}
        </div>

        <div class="prose">
          <slot />
        </div>

        {faqs.length > 0 && <FAQSection faqs={faqs} />}

        <FeedbackButtons slug={slug} />

        <ShareButtons title={title} url={url} />

        <div class="article-subscribe">
          <p class="article-subscribe-text">Enjoyed this article? Get more CRM tips straight to your inbox.</p>
          <NewsletterButton />
        </div>

        <ArticleComments slug={slug} />
      </div>

      <aside class="article-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <RelatedArticles articles={relatedArticles} />
  </article>
  <button class="back-to-top" aria-label="Back to top" type="button">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="5 12 10 7 15 12"></polyline>
    </svg>
  </button>
</BaseLayout>

<style>
  .article-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .article-header {
    margin-bottom: var(--space-10);
  }

  .article-category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .article-category:hover {
    color: var(--color-text-secondary);
  }

  .article-header h1 {
    margin-bottom: var(--space-4);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .meta-sep {
    color: var(--color-text-secondary);
  }

  .meta-avatar {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    object-fit: cover;
  }

  .meta-updated {
    font-style: italic;
  }

  .meta-author-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-link);
  }

  .meta-author-link:hover {
    text-decoration: underline;
  }

  .meta-author {
    font-weight: var(--weight-medium);
  }

  .meta-comments-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .meta-comments-link:hover {
    color: var(--color-link);
  }

  .meta-comments-icon {
    flex-shrink: 0;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .article-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .article-tag:hover {
    color: var(--color-text);
    border-color: var(--color-text-tertiary);
    background: var(--color-bg-card);
  }

  .article-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .article-main {
    min-width: 0;
  }

  .article-subscribe {
    margin-top: var(--space-8);
    padding: var(--space-6);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .article-subscribe-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .article-sidebar {
    display: none;
  }

  .reading-time-badge {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-sm);
  }

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: #e85d3a;
    z-index: calc(var(--z-header) + 1);
    transition: width 0.1s linear;
    pointer-events: none;
  }

  .back-to-top {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: #e85d3a;
    border: none;
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease, background 0.2s ease;
    z-index: var(--z-header);
    box-shadow: var(--shadow-md);
  }

  .back-to-top.visible {
    opacity: 1;
    visibility: visible;
  }

  .back-to-top:hover {
    background: #d14e2e;
  }

  @media (min-width: 1024px) {
    .article-layout {
      flex-direction: row;
      gap: var(--space-16);
    }

    .article-main {
      flex: 1;
      min-width: 0;
    }

    .article-sidebar {
      display: block;
      width: 260px;
      flex-shrink: 0;
      position: sticky;
      top: calc(56px + var(--space-6));
      align-self: flex-start;
    }
  }
</style>

<script>
  const countEl = document.querySelector('.meta-comment-count');
  if (countEl) {
    window.addEventListener('comments:loaded', ((e: CustomEvent) => {
      countEl.textContent = `(${e.detail.count})`;
    }) as EventListener);
  }

  // Reading progress bar
  const progressBar = document.querySelector('.reading-progress') as HTMLElement;
  const article = document.querySelector('.article-page') as HTMLElement;

  if (progressBar && article) {
    window.addEventListener('scroll', () => {
      const articleTop = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const scrollY = window.scrollY;
      const windowHeight = window.innerHeight;
      const progress = Math.min(
        100,
        Math.max(0, ((scrollY - articleTop) / (articleHeight - windowHeight)) * 100)
      );
      progressBar.style.width = `${progress}%`;
    }, { passive: true });
  }

  // Back to top button
  const backToTop = document.querySelector('.back-to-top') as HTMLElement;

  if (backToTop) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        backToTop.classList.add('visible');
      } else {
        backToTop.classList.remove('visible');
      }
    }, { passive: true });

    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
