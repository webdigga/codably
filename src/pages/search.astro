---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';
import { authors } from '../data/authors';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles.sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const catMap = Object.fromEntries(categories.map((c) => [c.slug, c.name]));
const authorMap = Object.fromEntries(
  Object.values(authors).map((a) => [a.slug, { name: a.name, avatar: a.avatar }])
);

function stripMarkdown(text: string): string {
  return text
    .replace(/#{1,6}\s+/g, '')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/`{1,3}[^`]*`{1,3}/g, '')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/^>\s+/gm, '')
    .replace(/^[-*+]\s+/gm, '')
    .replace(/^\d+\.\s+/gm, '')
    .replace(/\n{2,}/g, ' ')
    .replace(/\n/g, ' ')
    .trim();
}

const searchIndex = articles.map((article) => {
  const body = article.body || '';
  const plaintext = stripMarkdown(body);
  const excerpt = plaintext.split(/\s+/).slice(0, 300).join(' ');
  const authorInfo = authorMap[article.data.author];

  return {
    title: article.data.title,
    description: article.data.description,
    tags: article.data.tags || [],
    category: article.data.category,
    categoryName: catMap[article.data.category] || article.data.category,
    slug: article.id,
    author: article.data.author,
    authorName: authorInfo?.name || article.data.author,
    authorAvatar: authorInfo?.avatar || '',
    publishDate: article.data.publishDate,
    wordCount: body.split(/\s+/).length,
    excerpt,
  };
});
---

<BaseLayout
  title="Search Articles"
  description="Search Codably for practical coding articles and tutorials."
  noindex={true}
>
  <section class="container search-page">
    <div class="search-header">
      <h1>Search articles</h1>
      <p>Find practical CRM advice for your business.</p>
    </div>

    <div class="search-input-wrap">
      <svg class="search-input-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="9" r="6"></circle>
        <line x1="13.5" y1="13.5" x2="18" y2="18"></line>
      </svg>
      <input
        type="search"
        id="search-input"
        placeholder="Search by title, topic, or keyword..."
        autocomplete="off"
        autofocus
      />
    </div>

    <p id="search-count" class="search-count"></p>

    <div id="search-results" class="article-grid">
      {articles.slice(0, 9).map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          slug={article.id}
          category={article.data.category}
          author={article.data.author}
          publishDate={article.data.publishDate}
          wordCount={article.body ? article.body.split(/\s+/).length : 0}
        />
      ))}
    </div>

    <p id="no-results" class="no-results" hidden>No articles found. Try a different search term.</p>
  </section>
</BaseLayout>

<script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)} />

<script>
  import { buildCard } from '../utils/buildCard';

  interface SearchItem {
    title: string;
    description: string;
    tags: string[];
    category: string;
    categoryName: string;
    slug: string;
    author: string;
    authorName: string;
    authorAvatar: string;
    publishDate: string;
    wordCount: number;
    excerpt: string;
  }

  const indexEl = document.getElementById('search-index');
  const index: SearchItem[] = indexEl ? JSON.parse(indexEl.textContent || '[]') : [];

  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results')!;
  const noResults = document.getElementById('no-results')!;
  const countEl = document.getElementById('search-count')!;

  const MAX_RESULTS = 30;
  const initialHtml = resultsContainer.innerHTML;

  let debounceTimer: ReturnType<typeof setTimeout>;

  function search(query: string) {
    const q = query.toLowerCase().trim();

    resultsContainer.innerHTML = '';
    noResults.hidden = true;
    countEl.textContent = '';

    if (q.length < 3) {
      resultsContainer.innerHTML = initialHtml;
      if (!q) updateUrl('');
      return;
    }

    const terms = q.split(/\s+/);
    const matches: SearchItem[] = [];

    for (const item of index) {
      const haystack = [
        item.title,
        item.description,
        item.tags.join(' '),
        item.category.replace(/-/g, ' '),
        item.excerpt,
      ]
        .join(' ')
        .toLowerCase();

      if (terms.every((term) => haystack.includes(term))) {
        matches.push(item);
        if (matches.length >= MAX_RESULTS) break;
      }
    }

    if (matches.length === 0) {
      noResults.hidden = false;
    } else {
      matches.forEach((item) => resultsContainer.appendChild(buildCard(item)));
      countEl.textContent = matches.length >= MAX_RESULTS
        ? `Showing first ${MAX_RESULTS} results`
        : `${matches.length} result${matches.length === 1 ? '' : 's'}`;
    }

    updateUrl(query);
  }

  function updateUrl(query: string) {
    const url = new URL(window.location.href);
    if (query) {
      url.searchParams.set('q', query);
    } else {
      url.searchParams.delete('q');
    }
    history.replaceState(null, '', url.toString());
  }

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => search(input.value), 200);
  });

  input.addEventListener('search', () => {
    search(input.value);
  });

  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q');
  if (initialQuery) {
    input.value = initialQuery;
    search(initialQuery);
  }
</script>

<style>
  .search-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .search-header {
    margin-bottom: var(--space-8);
  }

  .search-header h1 {
    margin-bottom: var(--space-3);
  }

  .search-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .search-input-wrap {
    position: relative;
    margin-bottom: var(--space-8);
  }

  .search-input-icon {
    position: absolute;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-tertiary);
    pointer-events: none;
  }

  #search-input {
    width: 100%;
    padding: var(--space-3) var(--space-4) var(--space-3) var(--space-12);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  #search-input:focus {
    border-color: var(--color-text-secondary);
    box-shadow: 0 0 0 3px rgba(100, 116, 139, 0.15);
  }

  #search-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .search-count {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-6);
  }

  .search-count:empty {
    display: none;
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .no-results {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    text-align: center;
    padding: var(--space-16) 0;
  }
</style>
