---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { categories } from '../../data/categories';
import { authors } from '../../data/authors';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { category: article.data.category, slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

const wordCount = article.body ? article.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 230));

// Related articles: scored by category match (+2) and shared tags (+1 each)
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const currentTags = new Set(article.data.tags || []);
const relatedArticles = allArticles
  .filter((a) => a.id !== article.id)
  .map((a) => {
    let score = 0;
    if (a.data.category === article.data.category) score += 2;
    const aTags = a.data.tags || [];
    for (const tag of aTags) {
      if (currentTags.has(tag)) score += 1;
    }
    return { article: a, score };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) =>
    b.score - a.score ||
    new Date(b.article.data.publishDate).getTime() - new Date(a.article.data.publishDate).getTime()
  )
  .slice(0, 3)
  .map((item) => item.article);

const authorData = authors[article.data.author] || {
  name: article.data.author,
  role: '',
  linkedin: '',
};

const url = `https://crmbeat.com/${article.data.category}/${article.id}`;

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: article.data.title,
    description: article.data.description,
    datePublished: article.data.publishDate,
    dateModified: article.data.dateModified || article.data.publishDate,
    author: {
      '@type': 'Person',
      name: authorData.name,
      ...(authorData.role ? { jobTitle: authorData.role } : {}),
      ...(authorData.linkedin ? { sameAs: [authorData.linkedin] } : {}),
    },
    publisher: {
      '@type': 'Organization',
      name: 'CRM Beat',
      url: 'https://crmbeat.com',
    },
    mainEntityOfPage: url,
    wordCount: wordCount,
    timeRequired: `PT${readingTime}M`,
    keywords: article.data.tags?.join(', '),
  },
  ...(article.data.faqs && article.data.faqs.length > 0
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: article.data.faqs.map((faq: { question: string; answer: string }) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: faq.answer,
            },
          })),
        },
      ]
    : []),
];
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  publishDate={article.data.publishDate}
  dateModified={article.data.dateModified}
  author={article.data.author}
  category={article.data.category}
  slug={article.id}
  tags={article.data.tags}
  headings={headings}
  faqs={article.data.faqs}
  wordCount={wordCount}
  relatedArticles={relatedArticles}
  schemas={schemas}
>
  <Content />
</ArticleLayout>
