---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryTabs from '../../components/CategoryTabs.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Pagination from '../../components/Pagination.astro';
import SearchBar from '../../components/SearchBar.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/categories';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);

  return categories.flatMap((cat) => {
    const filtered = allArticles
      .filter((a) => a.data.category === cat.slug)
      .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

    return paginate(filtered, {
      params: { category: cat.slug },
      props: { category: cat },
      pageSize: 9,
    });
  });
};

const { page, category } = Astro.props;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: category.name },
];

const categoryTitle = page.currentPage > 1
  ? `${category.name} Articles - Page ${page.currentPage}`
  : `${category.name} Articles`;

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: category.name,
    description: category.description,
    url: `https://crmbeat.com/${category.slug}`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: page.data.map((article: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://crmbeat.com/${article.data.category}/${article.id}`,
    })),
  },
];

const prevUrl = page.url.prev || undefined;
const nextUrl = page.url.next || undefined;
---

<BaseLayout
  title={categoryTitle}
  description={category.description}
  schemas={schemas}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <section class="container category-page">
    <Breadcrumbs crumbs={crumbs} />

    <div class="category-header">
      <h1>{category.name}</h1>
      <p>{category.description}</p>
    </div>

    <SearchBar />

    <CategoryTabs activeCategory={category.slug} />

    {page.data.length > 0 ? (
      <div class="article-grid">
        {page.data.map((article: any) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.id}
            category={article.data.category}
            author={article.data.author}
            publishDate={article.data.publishDate}
            wordCount={article.body ? article.body.split(/\s+/).length : 0}
          />
        ))}
      </div>
    ) : (
      <p class="no-articles">No articles in this category yet. Check back soon!</p>
    )}

    <Pagination page={page} baseUrl={`/${category.slug}`} />
  </section>
</BaseLayout>

<style>
  .category-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .category-header {
    margin-bottom: var(--space-8);
  }

  .category-header h1 {
    margin-bottom: var(--space-3);
  }

  .category-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: var(--content-width);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .no-articles {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    text-align: center;
    padding: var(--space-16) 0;
  }
</style>
