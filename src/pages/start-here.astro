---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

const articleMap = new Map(allArticles.map((a) => [a.id, a]));

function getArticle(slug: string) {
  return articleMap.get(slug);
}

const sections = [
  {
    number: 1,
    title: 'Getting started',
    intro: 'New to developer productivity? These articles cover the fundamentals of building better engineering habits and choosing the right tools.',
    slugs: [
      'why-developer-productivity-matters-more-than-you-think',
      'the-developers-guide-to-deep-work',
    ],
  },
  {
    number: 2,
    title: 'Tools and workflows',
    intro: 'The right tools and workflows can transform how you work. These guides help you set up an environment that works for you.',
    slugs: [
      'terminal-tools-every-developer-should-know',
      'how-to-build-a-ci-cd-pipeline-that-actually-works',
      'ai-coding-assistants-a-practical-guide',
    ],
  },
  {
    number: 3,
    title: 'Code quality and collaboration',
    intro: 'Writing clean code and working well with others is what separates good engineers from great ones.',
    slugs: [
      'code-reviews-that-dont-waste-time',
      'technical-debt-when-to-fix-it-and-when-to-leave-it',
      'writing-documentation-developers-actually-read',
    ],
  },
  {
    number: 4,
    title: 'Growing your career',
    intro: 'Whether you want to go deep technically or move into leadership, these articles help you plan your next step.',
    slugs: [
      'the-senior-developer-mindset',
      'from-developer-to-tech-lead-what-actually-changes',
    ],
  },
];

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Start Here' },
];
---

<BaseLayout
  title="Start Here"
  description="New to Codably? Start here. A curated reading path covering developer productivity, tools, workflows, and career growth."
>
  <section class="container start-here">
    <Breadcrumbs crumbs={crumbs} />

    <div class="page-header">
      <h1>Start here</h1>
      <p>New to Codably? Follow this reading path from the basics through to advanced topics. Each section builds on the last, so you can learn at your own pace.</p>
    </div>

    {sections.map((section) => {
      const articles = section.slugs
        .map((slug) => getArticle(slug))
        .filter((a) => a != null);

      return (
        <div class="section">
          <div class="section-header">
            <span class="section-number">{section.number}</span>
            <div>
              <h2>{section.title}</h2>
              <p class="section-intro">{section.intro}</p>
            </div>
          </div>
          {articles.length > 0 && (
            <div class="article-grid">
              {articles.map((article) => (
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  slug={article.id}
                  category={article.data.category}
                  author={article.data.author}
                  publishDate={article.data.publishDate}
                  wordCount={article.body ? article.body.split(/\s+/).length : 0}
                />
              ))}
            </div>
          )}
        </div>
      );
    })}

    <div class="start-here-cta">
      <p>Ready to dive in? <a href="/">Browse all articles on the homepage</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .start-here {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .page-header {
    margin-bottom: var(--space-12);
  }

  .page-header h1 {
    margin-bottom: var(--space-3);
  }

  .page-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: var(--content-width);
  }

  .section {
    margin-bottom: var(--space-12);
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .section-number {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--brand-primary);
    color: #ffffff;
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    line-height: 1;
  }

  .section-header h2 {
    margin-bottom: var(--space-2);
  }

  .section-intro {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: var(--content-width);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .start-here-cta {
    margin-top: var(--space-8);
    padding: var(--space-6);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .start-here-cta p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  .start-here-cta a {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: var(--weight-medium);
  }

  .start-here-cta a:hover {
    text-decoration-thickness: 2px;
  }
</style>
