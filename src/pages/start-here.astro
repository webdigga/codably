---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const featured = sortedArticles.filter((a) => a.data.featured);
const recent = sortedArticles.slice(0, 6);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Start Here' },
];
---

<BaseLayout
  title="Start Here"
  description="New to CRM? Start here. The best articles to help your small business get started with CRM strategy."
>
  <section class="container start-here">
    <Breadcrumbs crumbs={crumbs} />

    <div class="page-header">
      <h1>Start here</h1>
      <p>New to CRM? These are the articles we recommend reading first. Practical advice to get your small business up and running.</p>
    </div>

    {featured.length > 0 && (
      <div class="section">
        <h2>Featured articles</h2>
        <div class="article-grid">
          {featured.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.id}
              category={article.data.category}
              author={article.data.author}
              publishDate={article.data.publishDate}
              wordCount={article.body ? article.body.split(/\s+/).length : 0}
            />
          ))}
        </div>
      </div>
    )}

    <div class="section">
      <h2>Most recent</h2>
      <div class="article-grid">
        {recent.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.id}
            category={article.data.category}
            author={article.data.author}
            publishDate={article.data.publishDate}
            wordCount={article.body ? article.body.split(/\s+/).length : 0}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .start-here {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .page-header {
    margin-bottom: var(--space-10);
  }

  .page-header h1 {
    margin-bottom: var(--space-3);
  }

  .page-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: var(--content-width);
  }

  .section {
    margin-bottom: var(--space-12);
  }

  .section h2 {
    margin-bottom: var(--space-6);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
