---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { slugifyTag, displayTag } from '../utils/tags';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

const tagCounts = new Map<string, number>();
for (const article of allArticles) {
  for (const tag of article.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}

const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tags' },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Tags',
    description: 'Browse all article tags on CRM Beat.',
    url: 'https://crmbeat.com/tags',
  },
];
---

<BaseLayout
  title="Tags"
  description="Browse all article tags on CRM Beat. Find articles by topic across every category."
  schemas={schemas}
>
  <section class="container tags-page">
    <Breadcrumbs crumbs={crumbs} />

    <div class="tags-header">
      <h1>Tags</h1>
      <p>Browse articles by topic. Tags cut across categories, so you can find everything we have written about a subject in one place.</p>
    </div>

    <div class="tag-cloud">
      {sortedTags.map(([tag, count]) => (
        <a href={`/tag/${slugifyTag(tag)}`} class="tag-pill">
          {displayTag(tag)}
          <span class="tag-count">{count}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .tags-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .tags-header {
    margin-bottom: var(--space-10);
  }

  .tags-header h1 {
    margin-bottom: var(--space-3);
  }

  .tags-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: var(--content-width);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .tag-pill:hover {
    background: var(--color-bg-card);
    color: var(--color-text);
    border-color: var(--color-text-tertiary);
  }

  .tag-count {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    background: var(--color-bg);
    border-radius: var(--radius-full);
    padding: 0 var(--space-2);
    min-width: 20px;
    text-align: center;
    line-height: 1.6;
  }
</style>
