---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryTabs from '../components/CategoryTabs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);
  const articles = allArticles.sort(
    (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );
  return paginate(articles, { pageSize: 9 });
};

const { page } = Astro.props;
const pageTitle = page.currentPage > 1 ? `Page ${page.currentPage}` : 'CRM Beat';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CRM Beat',
    url: 'https://crmbeat.com',
    description: 'Practical CRM strategy for small UK businesses.',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://crmbeat.com/search?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'CRM Beat',
    url: 'https://crmbeat.com',
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: page.data.slice(0, 10).map((article: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://crmbeat.com/${article.data.category}/${article.id}`,
    })),
  },
];

const prevUrl = page.url.prev || undefined;
const nextUrl = page.url.next || undefined;
---

<BaseLayout
  title={pageTitle}
  description="Practical CRM strategy for small UK businesses. Honest advice, no jargon, real results."
  schemas={schemas}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <section class="container homepage">
    <div class="homepage-header">
      <h1>CRM strategy that works</h1>
      <p>Practical advice for small UK businesses. No jargon, no fluff.</p>
    </div>

    <SearchBar />

    <CategoryTabs />

    <div class="article-grid">
      {page.data.map((article: any) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          slug={article.id}
          category={article.data.category}
          author={article.data.author}
          publishDate={article.data.publishDate}
          wordCount={article.body ? article.body.split(/\s+/).length : 0}
        />
      ))}
    </div>

    <Pagination page={page} baseUrl="" />
  </section>
</BaseLayout>

<style>
  .homepage {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .homepage-header {
    margin-bottom: var(--space-8);
  }

  .homepage-header h1 {
    margin-bottom: var(--space-3);
  }

  .homepage-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
