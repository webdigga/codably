---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryTabs from '../components/CategoryTabs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);
  const articles = allArticles.sort(
    (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );
  return paginate(articles, { pageSize: 9 });
};

const { page } = Astro.props;
const pageTitle = page.currentPage > 1 ? `Page ${page.currentPage}` : 'CRM Beat';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CRM Beat',
    url: 'https://crmbeat.com',
    description: 'Practical CRM strategy for small UK businesses.',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://crmbeat.com/search?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'CRM Beat',
    url: 'https://crmbeat.com',
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: page.data.slice(0, 10).map((article: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://crmbeat.com/${article.data.category}/${article.id}`,
    })),
  },
];

const prevUrl = page.url.prev || undefined;
const nextUrl = page.url.next || undefined;

// Build article map for client-side popular sections
const allArticlesForMap = await getCollection('articles', ({ data }) => !data.draft);
const articleMap: Record<string, { title: string; category: string }> = {};
for (const article of allArticlesForMap) {
  articleMap[article.id] = {
    title: article.data.title,
    category: article.data.category,
  };
}
---

<BaseLayout
  title={pageTitle}
  description="Practical CRM strategy for small UK businesses. Honest advice, no jargon, real results."
  schemas={schemas}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <section class="container homepage">
    <div class="homepage-header">
      <h1>CRM strategy that works</h1>
      <p>Practical advice for small UK businesses. No jargon, no fluff.</p>
    </div>

    <SearchBar />

    <CategoryTabs />

    <div class="article-grid">
      {page.data.map((article: any) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          slug={article.id}
          category={article.data.category}
          author={article.data.author}
          publishDate={article.data.publishDate}
          wordCount={article.body ? article.body.split(/\s+/).length : 0}
        />
      ))}
    </div>

    <Pagination page={page} baseUrl="" />

    <div class="popular-sections" style="display:none;">
      <div class="popular-grid">
        <section class="card popular-section" id="most-commented">
          <h2 class="popular-heading">Most commented</h2>
          <ol class="popular-list"></ol>
        </section>
        <section class="card popular-section" id="most-liked">
          <h2 class="popular-heading">Most liked</h2>
          <ol class="popular-list"></ol>
        </section>
      </div>
    </div>

    <script type="application/json" id="article-map" set:html={JSON.stringify(articleMap)}></script>
  </section>
</BaseLayout>

<style>
  .homepage {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .homepage-header {
    margin-bottom: var(--space-8);
  }

  .homepage-header h1 {
    margin-bottom: var(--space-3);
  }

  .homepage-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .popular-sections {
    margin-top: var(--space-12);
  }

  .popular-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .popular-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .popular-heading {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-4);
  }

  .popular-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .popular-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .popular-item a {
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .popular-item a:hover {
    color: var(--color-link);
  }

  .popular-badge {
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    background: var(--color-bg-alt);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
</style>

<script>
  const mapEl = document.getElementById('article-map');
  if (mapEl) {
    const articles: Record<string, { title: string; category: string }> = JSON.parse(mapEl.textContent || '{}');

    fetch('/api/stats')
      .then((res) => (res.ok ? res.json() : Promise.reject()))
      .then((data: { comments: Record<string, number>; votes: Record<string, { up: number; down: number }> }) => {
        const wrapper = document.querySelector('.popular-sections') as HTMLElement;
        if (!wrapper) return;

        // Most commented (top 3)
        const commentEntries = Object.entries(data.comments)
          .filter(([slug]) => articles[slug])
          .sort((a, b) => b[1] - a[1])
          .slice(0, 3);

        // Most liked by upvotes (top 3)
        const likeEntries = Object.entries(data.votes)
          .filter(([slug]) => articles[slug])
          .sort((a, b) => b[1].up - a[1].up)
          .slice(0, 3);

        if (commentEntries.length === 0 && likeEntries.length === 0) return;

        const commentList = document.querySelector('#most-commented .popular-list') as HTMLElement;
        const likeList = document.querySelector('#most-liked .popular-list') as HTMLElement;

        function populateList(list: HTMLElement, entries: [string, any][], getCount: (val: any) => number) {
          entries.forEach(([slug, val]) => {
            const article = articles[slug];
            if (!article) return;

            const li = document.createElement('li');
            li.className = 'popular-item';

            const link = document.createElement('a');
            link.href = `/${article.category}/${slug}`;
            link.textContent = article.title;

            const badge = document.createElement('span');
            badge.className = 'popular-badge';
            badge.textContent = String(getCount(val));

            li.appendChild(link);
            li.appendChild(badge);
            list.appendChild(li);
          });
        }

        if (commentEntries.length > 0 && commentList) {
          populateList(commentList, commentEntries, (count) => count);
        }

        if (likeEntries.length > 0 && likeList) {
          populateList(likeList, likeEntries, (votes) => votes.up);
        }

        // Hide empty sections
        if (commentEntries.length === 0) {
          document.getElementById('most-commented')?.remove();
        }
        if (likeEntries.length === 0) {
          document.getElementById('most-liked')?.remove();
        }

        wrapper.style.display = '';
      })
      .catch(() => {});
  }
</script>
