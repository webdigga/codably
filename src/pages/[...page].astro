---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryTabs from '../components/CategoryTabs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);
  const articles = allArticles.sort(
    (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );
  return paginate(articles, { pageSize: 9 });
};

const { page } = Astro.props;
const pageTitle = page.currentPage > 1 ? `Page ${page.currentPage}` : 'CRM Beat';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CRM Beat',
    url: 'https://crmbeat.com',
    description: 'Practical CRM strategy for small UK businesses.',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://crmbeat.com/search?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'CRM Beat',
    url: 'https://crmbeat.com',
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: page.data.slice(0, 10).map((article: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://crmbeat.com/${article.data.category}/${article.id}`,
    })),
  },
];

const prevUrl = page.url.prev || undefined;
const nextUrl = page.url.next || undefined;

// Lightweight article data for popular sections (built client-side from stats)
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const categoryMap: Record<string, string> = {};
for (const cat of (await import('../data/categories')).categories) {
  categoryMap[cat.slug] = cat.name;
}
const articleData = allArticles.map((a) => ({
  s: a.id,
  t: a.data.title,
  c: a.data.category,
  cn: categoryMap[a.data.category] || a.data.category,
}));
---

<BaseLayout
  title={pageTitle}
  description="Practical CRM strategy for small UK businesses. Honest advice, no jargon, real results."
  schemas={schemas}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <section class="container homepage">
    <div class="homepage-header">
      <h1>CRM strategy that works</h1>
      <p>Practical advice for small UK businesses. No jargon, no fluff.</p>
    </div>

    <SearchBar />

    <CategoryTabs />

    <div class="article-grid">
      {page.data.map((article: any) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          slug={article.id}
          category={article.data.category}
          author={article.data.author}
          publishDate={article.data.publishDate}
          wordCount={article.body ? article.body.split(/\s+/).length : 0}
        />
      ))}
    </div>

    <Pagination page={page} baseUrl="" />

    <div class="popular-sections" style="display:none;">
      <section id="most-commented">
        <h2 class="popular-heading">Most commented</h2>
        <div class="article-grid popular-grid"></div>
      </section>
      <section id="most-liked">
        <h2 class="popular-heading">Most liked</h2>
        <div class="article-grid popular-grid"></div>
      </section>
    </div>

    <script id="article-data" type="application/json" set:html={JSON.stringify(articleData)} />
  </section>
</BaseLayout>

<style>
  .homepage {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .homepage-header {
    margin-bottom: var(--space-8);
  }

  .homepage-header h1 {
    margin-bottom: var(--space-3);
  }

  .homepage-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .popular-sections {
    margin-top: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .popular-heading {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-6);
  }

  :global(.popular-card) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-decoration: none;
    color: inherit;
    padding: var(--space-4);
    transition: border-color var(--transition-fast);
  }

  :global(.popular-card:hover) {
    border-color: var(--color-link);
    color: inherit;
  }

  :global(.popular-card-category) {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-tertiary);
  }

  :global(.popular-card-title) {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  :global(.popular-card:hover .popular-card-title) {
    color: var(--color-link);
  }
</style>

<script>
  const dataEl = document.getElementById('article-data');
  if (dataEl) {
    const articles: { s: string; t: string; c: string; cn: string }[] = JSON.parse(dataEl.textContent || '[]');
    const bySlug = new Map(articles.map((a) => [a.s, a]));

    fetch('/api/stats')
      .then((res) => (res.ok ? res.json() : Promise.reject()))
      .then((data: { comments: Record<string, number>; votes: Record<string, { up: number; down: number }> }) => {
        const wrapper = document.querySelector('.popular-sections') as HTMLElement;
        if (!wrapper) return;

        const commentSlugs = Object.entries(data.comments)
          .filter(([slug]) => bySlug.has(slug))
          .sort((a, b) => b[1] - a[1])
          .slice(0, 3)
          .map(([slug]) => slug);

        const likeSlugs = Object.entries(data.votes)
          .filter(([slug]) => bySlug.has(slug))
          .sort((a, b) => b[1].up - a[1].up)
          .slice(0, 3)
          .map(([slug]) => slug);

        if (commentSlugs.length === 0 && likeSlugs.length === 0) return;

        function buildCard(slug: string): HTMLElement | null {
          const info = bySlug.get(slug);
          if (!info) return null;
          const a = document.createElement('a');
          a.href = `/${info.c}/${info.s}`;
          a.className = 'popular-card card';
          a.innerHTML =
            `<span class="popular-card-category">${info.cn}</span>` +
            `<span class="popular-card-title">${info.t}</span>`;
          return a;
        }

        const commentGrid = document.querySelector('#most-commented .popular-grid') as HTMLElement;
        const likeGrid = document.querySelector('#most-liked .popular-grid') as HTMLElement;

        if (commentSlugs.length > 0 && commentGrid) {
          commentSlugs.forEach((slug) => {
            const card = buildCard(slug);
            if (card) commentGrid.appendChild(card);
          });
        } else {
          document.getElementById('most-commented')?.remove();
        }

        if (likeSlugs.length > 0 && likeGrid) {
          likeSlugs.forEach((slug) => {
            const card = buildCard(slug);
            if (card) likeGrid.appendChild(card);
          });
        } else {
          document.getElementById('most-liked')?.remove();
        }

        wrapper.style.display = '';
      })
      .catch(() => {});
  }
</script>
