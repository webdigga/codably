---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryTabs from '../components/CategoryTabs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);
  const articles = allArticles.sort(
    (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );
  return paginate(articles, { pageSize: 9 });
};

const { page } = Astro.props;
const pageTitle = page.currentPage > 1 ? `Page ${page.currentPage}` : 'Codably';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Codably',
    url: 'https://codably.dev',
    description: 'Practical developer productivity advice. Better tools, sharper workflows, real results.',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://codably.dev/search?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Codably',
    url: 'https://codably.dev',
    logo: 'https://codably.dev/images/codably-logo.png',
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: page.data.slice(0, 10).map((article: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://codably.dev/${article.data.category}/${article.id}`,
    })),
  },
];

const prevUrl = page.url.prev || undefined;
const nextUrl = page.url.next || undefined;

---

<BaseLayout
  title={pageTitle}
  description="Practical developer productivity advice. Better tools, sharper workflows, real results."
  schemas={schemas}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <section class="container homepage">
    <div class="homepage-header">
      <h1>Developer productivity that works</h1>
      <p>Practical advice for engineers who want to ship better software, faster.</p>
    </div>

    <SearchBar />

    <CategoryTabs />

    <div class="article-grid">
      {page.data.map((article: any) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          slug={article.id}
          category={article.data.category}
          author={article.data.author}
          publishDate={article.data.publishDate}
          wordCount={article.body ? article.body.split(/\s+/).length : 0}
        />
      ))}
    </div>

    <Pagination page={page} baseUrl="" />

    <div class="popular-sections" style="display:none;">
      <section id="most-commented">
        <h2 class="popular-heading">Most commented</h2>
        <div class="article-grid popular-grid"></div>
      </section>
      <section id="most-liked">
        <h2 class="popular-heading">Most liked</h2>
        <div class="article-grid popular-grid"></div>
      </section>
    </div>

  </section>
</BaseLayout>

<style>
  .homepage {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .homepage-header {
    margin-bottom: var(--space-8);
  }

  .homepage-header h1 {
    margin-bottom: var(--space-3);
  }

  .homepage-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .popular-sections {
    margin-top: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .popular-heading {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-6);
  }

</style>

<script>
  import { buildCard, type ArticleInfo } from '../utils/buildCard';

  const wrapper = document.querySelector('.popular-sections') as HTMLElement;
  if (wrapper) {
    Promise.all([
      fetch('/api/stats').then((r) => (r.ok ? r.json() : Promise.reject())),
      fetch('/articles.json').then((r) => (r.ok ? r.json() : Promise.reject())),
    ])
      .then(([stats, articles]: [
        { comments: Record<string, number>; votes: Record<string, { up: number; down: number }> },
        ArticleInfo[]
      ]) => {
        const bySlug = new Map(articles.map((a) => [a.slug, a]));

        const commentSlugs = Object.entries(stats.comments)
          .filter(([slug]) => bySlug.has(slug))
          .sort((a, b) => b[1] - a[1])
          .slice(0, 3)
          .map(([slug]) => slug);

        const likeSlugs = Object.entries(stats.votes)
          .filter(([slug]) => bySlug.has(slug))
          .sort((a, b) => b[1].up - a[1].up)
          .slice(0, 3)
          .map(([slug]) => slug);

        if (commentSlugs.length === 0 && likeSlugs.length === 0) return;

        const commentGrid = document.querySelector('#most-commented .popular-grid') as HTMLElement;
        const likeGrid = document.querySelector('#most-liked .popular-grid') as HTMLElement;

        if (commentSlugs.length > 0 && commentGrid) {
          commentSlugs.forEach((slug) => {
            const info = bySlug.get(slug);
            if (info) commentGrid.appendChild(buildCard(info));
          });
        } else {
          document.getElementById('most-commented')?.remove();
        }

        if (likeSlugs.length > 0 && likeGrid) {
          likeSlugs.forEach((slug) => {
            const info = bySlug.get(slug);
            if (info) likeGrid.appendChild(buildCard(info));
          });
        } else {
          document.getElementById('most-liked')?.remove();
        }

        wrapper.style.display = '';
      })
      .catch(() => {});
  }
</script>
