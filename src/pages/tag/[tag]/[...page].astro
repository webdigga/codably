---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { slugifyTag, displayTag } from '../../../utils/tags';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);

  // Build a map of tag slug -> { display name, articles }
  const tagMap = new Map<string, { name: string; articles: typeof allArticles }>();

  for (const article of allArticles) {
    for (const tag of article.data.tags) {
      const slug = slugifyTag(tag);
      if (!tagMap.has(slug)) {
        tagMap.set(slug, { name: tag, articles: [] });
      }
      tagMap.get(slug)!.articles.push(article);
    }
  }

  return [...tagMap.entries()].flatMap(([slug, { name, articles }]) => {
    const sorted = articles.sort(
      (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
    );

    return paginate(sorted, {
      params: { tag: slug },
      props: { tagName: name },
      pageSize: 9,
    });
  });
};

const { page, tagName: rawTagName } = Astro.props;
const { tag } = Astro.params;

const tagName = displayTag(rawTagName);

const pageTitle = page.currentPage > 1
  ? `Articles tagged "${tagName}" - Page ${page.currentPage}`
  : `Articles tagged "${tagName}"`;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tags', href: '/tags' },
  { label: tagName },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `Articles tagged "${tagName}"`,
    description: `All Codably articles tagged with "${tagName}".`,
    url: `https://codably.dev/tag/${tag}`,
  },
];

const prevUrl = page.url.prev || undefined;
const nextUrl = page.url.next || undefined;
---

<BaseLayout
  title={pageTitle}
  description={`All Codably articles tagged with "${tagName}". Practical coding advice and tutorials.`}
  schemas={schemas}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <section class="container tag-page">
    <Breadcrumbs crumbs={crumbs} />

    <div class="tag-header">
      <span class="tag-label">Tag</span>
      <h1>{tagName}</h1>
      <p>{page.total} {page.total === 1 ? 'article' : 'articles'} tagged with "{tagName}"</p>
    </div>

    {page.data.length > 0 ? (
      <div class="article-grid">
        {page.data.map((article: any) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.id}
            category={article.data.category}
            author={article.data.author}
            publishDate={article.data.publishDate}
            wordCount={article.body ? article.body.split(/\s+/).length : 0}
          />
        ))}
      </div>
    ) : (
      <p class="no-articles">No articles with this tag yet.</p>
    )}

    <Pagination page={page} baseUrl={`/tag/${tag}`} />
  </section>
</BaseLayout>

<style>
  .tag-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .tag-header {
    margin-bottom: var(--space-10);
  }

  .tag-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2);
  }

  .tag-header h1 {
    margin-bottom: var(--space-3);
  }

  .tag-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .article-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .no-articles {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    text-align: center;
    padding: var(--space-16) 0;
  }
</style>
